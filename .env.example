# Django settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=elitewealthcapita.uk,www.elitewealthcapita.uk,.onrender.com,localhost

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=elite_wealth
DB_USER=elite_user
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# Redis/Celery
# Use your Redis provider URL (Render Redis or Upstash), e.g.:
#   redis://red-xxxx:6379          (Render internal URL)
#   rediss://:password@host:port   (Upstash TLS URL)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email
# Gmail: enable 2-Step Verification then generate an App Password at
# https://myaccount.google.com/apppasswords and use it as EMAIL_HOST_PASSWORD
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@elitewealthcapita.uk

# Admin notification email (receives system alerts)
ADMIN_NOTIFICATION_EMAIL=admin@elitewealthcapita.uk

# Superuser credentials (for automated setup)
DJANGO_SUPERUSER_EMAIL=admin@elitewealthcapita.uk
DJANGO_SUPERUSER_PASSWORD=generate-a-secure-password
